# ============================================================================
# CyfyClaw — Environment Configuration
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# ============================================================================

# ---- Shared credential (backend only — never exposed to the frontend) --------
# Hugging Face access token with "Inference Providers" scope. Shared by BOTH
# agents (both are served via Hugging Face). Create one at:
#   https://huggingface.co/settings/tokens
HF_TOKEN=

# ---- Dual agents (change models by editing ONLY these lines) -----------------
# CyfyClaw runs two INDEPENDENT agents in parallel. Nothing is hardcoded — swap
# either model, or point at a self-hosted vLLM/SGLang/TGI endpoint, via env only.
#
# Many HF-routed models require a provider suffix (":novita", ":fireworks-ai",
# ":together", ":auto", ...). Verify the exact id + available provider on the
# model page's "Deploy -> Inference Providers" panel before deploying.

# Agent 1 — Chief Detection Engineer (Kimi-K2.7-Code).
#   Model page: https://huggingface.co/moonshotai/Kimi-K2.7-Code
#   (Novita is the currently listed HF Inference Provider for this model.)
KIMI_MODEL=moonshotai/Kimi-K2.7-Code:novita
KIMI_BASE_URL=https://router.huggingface.co/v1

# Agent 2 — Principal Security Reviewer (DeepSeek-R1).
#   Model page: https://huggingface.co/deepseek-ai/DeepSeek-R1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-R1:auto
DEEPSEEK_BASE_URL=https://router.huggingface.co/v1

# Optional per-agent temperature overrides (fall back to LLM_TEMPERATURE).
# KIMI_TEMPERATURE=0.2
# DEEPSEEK_TEMPERATURE=0.2

# ---- Generation controls (shared defaults) -----------------------------------
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
# Timeout in seconds. LLM_TIMEOUT and LLM_TIMEOUT_SECONDS are both accepted.
LLM_TIMEOUT=300

# ---- Legacy single-agent settings (backward compatibility) -------------------
# Still honoured. If DEEPSEEK_MODEL / DEEPSEEK_BASE_URL are left blank, the
# DeepSeek agent falls back to these values.
HF_MODEL_ID=deepseek-ai/DeepSeek-R1:auto
LLM_BASE_URL=https://router.huggingface.co/v1

# ---- Backend server ----
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins for the frontend.
FRONTEND_URL=http://localhost:3000

# ---- Frontend (build-time; safe to expose — contains NO secrets) ----
# Base URL the browser uses to reach the backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
